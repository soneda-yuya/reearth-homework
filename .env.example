# Local development environment variables.
# Copy to `.env` and fill in real values. `.env` is gitignored.
# In cloud environments, these are injected by Terraform (env.value_source for secrets).

# Platform common (all deployables)
PLATFORM_SERVICE_NAME=bff           # ingestion | bff | notifier | cmsmigrate
PLATFORM_ENV=dev                    # dev | prod
PLATFORM_LOG_LEVEL=INFO
PLATFORM_OTEL_EXPORTER=stdout       # stdout | gcp
PLATFORM_GCP_PROJECT_ID=overseas-safety-map

# Ingestion-specific (U-ING で利用)
# INGESTION_MOFA_BASE_URL=https://www.ezairyu.mofa.go.jp/html/opendata
# INGESTION_PUBSUB_TOPIC=safety-incident.new-arrival
# INGESTION_CLAUDE_API_KEY=           # in cloud: Secret Manager
# INGESTION_MAPBOX_API_KEY=           # in cloud: Secret Manager
# INGESTION_CMS_BASE_URL=
# INGESTION_CMS_WORKSPACE_ID=
# INGESTION_CMS_INTEGRATION_TOKEN=    # in cloud: Secret Manager

# BFF-specific (U-BFF で利用)
# BFF_PORT=8080
# BFF_FIREBASE_PROJECT_ID=overseas-safety-map
# BFF_CMS_BASE_URL=
# BFF_CMS_WORKSPACE_ID=
# BFF_CMS_INTEGRATION_TOKEN=          # in cloud: Secret Manager

# Notifier-specific (U-NTF で利用)
# NOTIFIER_PUBSUB_SUBSCRIPTION=notifier-safety-incident-new-arrival
# NOTIFIER_FIREBASE_PROJECT_ID=overseas-safety-map

# Cmsmigrate-specific (U-CSS で利用、旧 SETUP_*)
# CMSMIGRATE_CMS_BASE_URL=
# CMSMIGRATE_CMS_WORKSPACE_ID=
# CMSMIGRATE_CMS_INTEGRATION_TOKEN=   # in cloud: Secret Manager
