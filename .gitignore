# Go build artifacts
/bin/
/dist/
*.test
*.out
*.prof

# Generated protobuf Go (committed but protect against stale intermediates)
gen/**/*.pb.go.tmp

# Environment / secrets
.env
.env.local
.env.*.local
# Allow the sanitised template to remain tracked even when it resembles
# one of the patterns above / below. Keeps `.env.example` visible for newcomers.
!.env.example

# Generic secret-bearing material
*.pem
*.key
*.p8
*.p12
*.jks
*.keystore
credentials.json
service-account*.json
*-service-account.json

# Firebase per-project scaffold (generated by `flutterfire configure`)
google-services.json
GoogleService-Info.plist
firebase.json
.firebaserc

# Android app signing
android/key.properties
**/debug.keystore
**/release.keystore

# IDE / editor
.idea/
.vscode/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Terraform
**/.terraform/
**/*.tfstate
**/*.tfstate.backup
**/*.tfplan
**/crash.log
terraform/environments/*/plan.txt

# Claude Code agent scratch
.claude/scheduled_tasks.lock

# Coverage
coverage.out
coverage.html

# pgregory.net/rapid writes reproducer files under testdata/rapid on failure.
# They are tied to a specific run's seed and should not be tracked.
**/testdata/rapid/
